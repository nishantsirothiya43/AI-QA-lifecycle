# ── AI Provider Selection ──────────────────────────────────────
# Choose ONE: gemini | ollama | claude
AI_PROVIDER=gemini

# Common gotcha:
# If you set AI_PROVIDER=claude, the app will call Anthropic — not Gemini — even if you updated GEMINI_API_KEY.

# Set to true to use deterministic local mocks (no paid API calls).
# When AI_PROVIDER=claude, MOCK_LLM=true uses the built-in Claude mock instead of Anthropic HTTP.
MOCK_LLM=false

# ── Google Gemini ──────────────────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBYuJlcS8uTj0RFHydgEKhsGEcKmhbi1N8
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local) ─────────────────────────────────────────────
# Install from https://ollama.com and run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Anthropic Claude ───────────────────────────────────────────
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
